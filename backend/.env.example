NODE_ENV=development
PORT=3002

DATABASE_URL=postgresql://<user>:<password>@localhost:5432/timemanagement

JWT_SECRET=your-super-secret-jwt-key-min-16-chars
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
